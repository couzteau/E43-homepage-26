---
import TouristLayout from '../layouts/TouristLayout.astro';
import ButtondownSignup from '../components/ButtondownSignup.astro';
import { Image } from 'astro:assets';
import Lightbox from '../components/Lightbox.astro';
import pole1 from '../assets/tourist/pole1.jpg';
import spiralStaircase from '../assets/tourist/SpiralStaircase.jpg';
import tower from '../assets/tourist/Tower.jpg';
import artSpan from '../assets/tourist/ArtSpan.jpg';
import door from '../assets/tourist/Door.jpg';
import holymoly from '../assets/tourist/holymoly.jpeg';
---

<TouristLayout
  title="You Found the Princess Diaries Firehouse"
  description="724 Brazil Ave, San Francisco's Excelsior District. A working firehouse since 1912. Mia Thermopolis's home since 2001. A residence and community art space today."
>

  <!-- HERO -->
  <section class="hero-proclamation">
    <div class="hero-proclamation-inner">

      <div class="proclamation-ornament proclamation-ornament-top" aria-hidden="true">
        <span class="orn-line"></span>
        <span class="orn-glyph">✦</span>
        <span class="orn-line"></span>
      </div>

      <img
        src="/images/E43-Mia-Logo-final.png"
        alt="Engine No. 43 — Mia Thermopolis medallion seal"
        class="proclamation-medallion"
        width="260"
        height="260"
      />

      <h1 class="proclamation-headline">You found the<br />Princess Diaries firehouse.</h1>

      <p class="proclamation-address">724 Brazil Ave · San Francisco's Excelsior District</p>

      <p class="proclamation-sub">A working firehouse since 1912. Mia Thermopolis's home since 2001. A residence and community art space today.</p>

      <div class="proclamation-ornament proclamation-ornament-bottom" aria-hidden="true">
        <span class="orn-line"></span>
        <span class="orn-glyph">✦</span>
        <span class="orn-line"></span>
      </div>

    </div>
  </section>

  <!-- INSIDE THE FIREHOUSE -->
  <section class="section section-hero-flipped">
    <div class="container">
      <h2 class="section-title">Inside the Firehouse</h2>
      <p class="section-intro">Here's what's behind the big red doors.</p>
      <div class="gallery-grid">
        <figure class="gallery-item" data-lightbox>
          <Image src={artSpan} alt="The firehouse garage" widths={[400, 800]} sizes="(max-width: 640px) 100vw, 50vw" loading="eager" />
          <figcaption>
            <strong>The Garage</strong>
            Where Engine No. 43 once parked. Now it hosts art markets, music, and community gatherings.
          </figcaption>
        </figure>
        <figure class="gallery-item" data-lightbox>
          <Image src={spiralStaircase} alt="The original cast iron spiral staircase" widths={[400, 800]} sizes="(max-width: 640px) 100vw, 50vw" loading="lazy" />
          <figcaption>
            <strong>The Spiral Staircase</strong>
            The original cast iron staircase the firefighters used. Mia walked these same steps.
          </figcaption>
        </figure>
        <figure class="gallery-item" data-lightbox>
          <Image src={pole1} alt="The fire pole at Engine 43" widths={[400, 800]} sizes="(max-width: 640px) 100vw, 50vw" loading="lazy" />
          <figcaption>
            <strong>The Pole</strong>
            Yes, it's real. Yes, it still works. It runs from the third floor all the way down to the garage — just like in the movie.
          </figcaption>
        </figure>
        <figure class="gallery-item" data-lightbox>
          <Image src={tower} alt="The Princess Tower — now an art studio" widths={[400, 800]} sizes="(max-width: 640px) 100vw, 50vw" loading="lazy" class="align-top" />
          <figcaption>
            <strong>The Princess Tower</strong>
            The hose-drying tower is now an art studio. On a clear day you can see downtown, the bay, and the hills of the Excelsior.
          </figcaption>
        </figure>
      </div>
      <p class="gallery-cats-link"><a href="/cats">Meet Fat Louie's cousins &rarr;</a></p>
    </div>
  </section>

  <!-- THE DOOR -->
  <section class="section section-hero-bg door-section">
    <div class="door-layout">
      <div class="door-image" data-lightbox>
        <Image src={door} alt="Resist Much Obey Little — Princess Mia and Princess Leia door mural" widths={[600, 1200]} sizes="(max-width: 640px) 100vw, 55vw" loading="lazy" />
      </div>
      <div class="door-text">
        <p class="door-eyebrow">The door · 724 Brazil Ave</p>
        <h2 class="door-headline">Princesses<br />can be<br />rebels.</h2>
        <p>The two women on our door are Princess Mia — pre-transformation, wild curly hair intact — and her sister in spirit, Princess Leia.</p>
        <p>This is the Excelsior — a neighborhood of immigrants, families, and working people. We watch out for each other here. We warn our neighbors. We show up.</p>
        <blockquote class="door-manifesto">Take a photo. Share it. The more people see it, the further the message travels.</blockquote>
      </div>
    </div>
  </section>

  <!-- HOLY MOLY CHRISTMAS MARKET -->
  <section class="section section-hero-flipped text-center">
    <div class="container">
      <h2 class="section-title">Come back in December.</h2>
      <div class="holymoly-photo" data-lightbox>
        <Image src={holymoly} alt="Holy Moly Christmas Market 2025 — view from above" widths={[400, 800, 1200]} sizes="(max-width: 640px) 100vw, 90vw" loading="lazy" />
        <p class="photo-caption">Holy Moly Christmas Market 2025 — view from above.</p>
      </div>
      <p class="holymoly-body">Every year we transform the firehouse into San Francisco's most unexpected holiday market. Local artists, handmade goods, live music, and neighbors spilling out onto Brazil Ave.</p>
      <p class="holymoly-body">It started small in 2020 to support our local artist community. Last year we had lines around the block.</p>
      <p class="holymoly-date">December 2026 date coming soon.</p>
      <a href="#signup" class="btn">Sign up to be first to know</a>
    </div>
  </section>

  <!-- NEWSLETTER SIGNUP -->
  <section id="signup" class="section section-hero-bg">
    <div class="container">
      <ButtondownSignup
        heading="Stay connected."
        description="Be the first to know when Holy Moly tickets drop. Get updates on art markets, events, and what's happening at the firehouse. We send a few emails a year — only when it matters."
        buttonText="Sign me up"
      />
    </div>
  </section>

  <!-- MIA & FAT LOUIE'S + SCREENPRINTING -->
  <section class="section section-hero-flipped">
    <div class="container cta-pair">
      <div class="cta-block">
        <h2>Mia &amp; Fat Louie's</h2>
        <p>Art, prints, and handmade goods from our studio — named after the princess and her orange tabby.</p>
        <a href="https://www.etsy.com/shop/Engine43ArtStore" class="btn btn-outline" target="_blank" rel="noopener noreferrer">Visit the shop &rarr;</a>
      </div>
      <div class="cta-block">
        <h2>Learn to screenprint.</h2>
        <p>Carolin teaches hands-on screenprinting workshops right here in the firehouse studio. No experience needed — you'll leave with your own prints and the skills to make more.</p>
        <a href="/classes" class="btn btn-outline">Book a class &rarr;</a>
      </div>
    </div>
  </section>

  <!-- SIGN-OFF -->
  <section class="section section-hero-bg text-center">
    <div class="container signoff">
      <h2>The door's open.</h2>
      <p>We host markets, music, and community events throughout the year.</p>
      <p>Follow us or sign up above — we'd love to see you back.</p>
      <p class="footer-links">
        <a href="/project/listening-room">Interested in our listening room sessions? Learn more &rarr;</a>
      </p>
    </div>
  </section>

  <Lightbox />
</TouristLayout>

<style>
  /* ── HERO: ROYAL PROCLAMATION ── */
  .hero-proclamation {
    /* Use the sky gradient — dramatic in both light + dark via CSS vars */
    background: var(--hero-small-gradient);
    color: white;
    padding: var(--spacing-2xl) var(--spacing-md);
    text-align: center;
  }

  .hero-proclamation-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
    animation: proclamation-arrive 0.7s ease both;
  }

  @keyframes proclamation-arrive {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Ornamental border rule ── */
  .proclamation-ornament {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    width: 100%;
  }

  .orn-line {
    flex: 1;
    height: 1px;
    background: white;
    opacity: 0.35;
  }

  .orn-glyph {
    color: white;
    font-size: 0.75rem;
    opacity: 0.6;
    flex-shrink: 0;
  }

  .proclamation-ornament-top {
    margin-bottom: calc(var(--spacing-lg) * -0.5);
  }

  .proclamation-ornament-bottom {
    margin-top: calc(var(--spacing-lg) * -0.5);
  }

  /* ── Medallion ── */
  .proclamation-medallion {
    width: 260px;
    height: 260px;
    object-fit: contain;
    display: block;
    animation: medallion-drop 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s both;
  }

  @keyframes medallion-drop {
    from { opacity: 0; transform: scale(0.88); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Headline ── */
  .proclamation-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 2.75rem;
    line-height: 1.15;
    color: white;
    margin: 0;
    animation: proclamation-arrive 0.7s ease 0.25s both;
  }

  /* ── Address ── */
  .proclamation-address {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: white;
    opacity: 0.8;
    margin: 0;
    animation: proclamation-arrive 0.7s ease 0.35s both;
  }

  /* ── Subtitle ── */
  .proclamation-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    font-size: 1.125rem;
    line-height: 1.7;
    color: white;
    opacity: 0.9;
    max-width: 480px;
    margin: 0;
    animation: proclamation-arrive 0.7s ease 0.4s both;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .hero-proclamation {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .hero-proclamation-inner {
      gap: var(--spacing-md);
    }

    .proclamation-medallion {
      width: 160px;
      height: 160px;
    }

    .proclamation-headline {
      font-size: 2rem;
    }

    .proclamation-sub {
      font-size: 1rem;
    }
  }

  /* ── Narrow (iPhone SE, 375px) ── */
  @media (max-width: 400px) {
    .proclamation-headline {
      font-size: 1.65rem;
    }

    .proclamation-medallion {
      width: 130px;
      height: 130px;
    }
  }

  /* ── GALLERY CATS LINK ── */
  .gallery-cats-link {
    text-align: center;
    margin-top: var(--spacing-xl);
    font-family: var(--font-ui);
    font-size: 0.875rem;
    letter-spacing: 0.06em;
  }

  /* ── GALLERY ── */
  .section-intro {
    text-align: center;
    color: var(--color-text-muted);
    margin: 0 auto var(--spacing-xl);
    font-size: 1.125rem;
    max-width: 560px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .gallery-item {
    margin: 0;
    cursor: pointer;
  }

  .gallery-item img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    transition: opacity 0.15s ease;
  }

  .gallery-item:hover img {
    opacity: 0.85;
  }

  .gallery-item img.align-top {
    object-position: top;
  }

  .gallery-item figcaption {
    padding: var(--spacing-sm) 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .gallery-item figcaption strong {
    display: block;
    color: var(--color-text);
    font-family: var(--font-display);
    font-style: var(--heading-style);
    font-weight: var(--heading-weight);
    font-size: 1.05rem;
    margin-bottom: 2px;
  }

  /* ── DOOR ── */
  .door-section {
    padding: 0;
    overflow: hidden;
  }

  .door-layout {
    display: grid;
    grid-template-columns: 55% 45%;
    min-height: 600px;
  }

  .door-image {
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .door-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 0.6s ease;
  }

  .door-image:hover img {
    transform: scale(1.03);
  }

  .door-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--spacing-2xl) var(--spacing-2xl) var(--spacing-2xl) var(--spacing-xl);
  }

  .door-eyebrow {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 var(--spacing-md);
  }

  .door-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 3.5rem;
    line-height: 1.05;
    letter-spacing: normal;
    text-transform: none;
    color: inherit;
    margin: 0 0 var(--spacing-xl);
  }

  .door-text p {
    margin-bottom: var(--spacing-md);
    font-size: 0.975rem;
    line-height: 1.7;
  }

  .door-manifesto {
    margin: var(--spacing-xl) 0 0;
    padding: var(--spacing-md) 0 var(--spacing-md) var(--spacing-lg);
    border-left: 2px solid var(--color-primary);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  /* ── DOOR MOBILE ── */
  @media (max-width: 640px) {
    .door-layout {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .door-image {
      /* Let the image show at its natural ratio — don't crop the murals */
      height: auto;
      aspect-ratio: 3 / 4;
    }

    .door-image img {
      object-position: center bottom;
    }

    .door-text {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .door-headline {
      font-size: 2.5rem;
    }
  }

  /* ── HOLY MOLY ── */
  .holymoly-photo {
    margin-bottom: var(--spacing-xl);
    cursor: pointer;
  }

  .holymoly-photo img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
  }

  .photo-caption {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-family: var(--font-ui);
    text-align: center;
    margin-top: var(--spacing-sm);
  }

  .holymoly-body {
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  .holymoly-date {
    font-family: var(--font-ui);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  /* ── CTA PAIR ── */
  .cta-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
  }

  .cta-block {
    display: flex;
    flex-direction: column;
  }

  .cta-block .btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .cta-block h2 {
    margin-bottom: var(--spacing-md);
  }

  .cta-block p {
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-muted);
  }

  /* ── SIGN-OFF ── */
  .signoff {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .signoff p {
    margin-bottom: var(--spacing-md);
  }

  .footer-links {
    margin-top: var(--spacing-xl);
    font-size: 1rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .footer-links a {
    color: var(--color-text-muted);
  }

  .divider {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-item img {
      height: 220px;
    }

    .cta-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
