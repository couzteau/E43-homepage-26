---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import mia from '../assets/tourist/cats/Mia.jpg';
import miaSun from '../assets/tourist/cats/mia-sun.jpg';
import mia2 from '../assets/tourist/cats/2-mia.jpg';
import emerald from '../assets/tourist/cats/Emerald.jpg';
import emerald2 from '../assets/tourist/cats/2-emerald.jpg';
import emerald3 from '../assets/tourist/cats/Emerald2.jpg';
import zaphire1 from '../assets/tourist/cats/1-Zaphire.jpg';
import zaphire2 from '../assets/tourist/cats/2-zaphire.jpg';
import zaphire3 from '../assets/tourist/cats/3-Zaphire.jpg';
import majorTom from '../assets/tourist/cats/Major-Tom.jpg';
import tom1 from '../assets/tourist/cats/1-tom.jpg';
import tom3 from '../assets/tourist/cats/3-tom.jpg';
import emeraldZaphire from '../assets/tourist/cats/Emerald+Zaphire.jpg';
import emeraldZaphire2 from '../assets/tourist/cats/Emerald+Zaphire2.jpg';
import miaAndTom from '../assets/tourist/cats/Mia+Tom.jpg';

const catSizes = '(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw';
---

<BaseLayout
  title="The Firehouse Cats"
  description="Meet Mia, Emerald, Zaphire, and Major Tom — Fat Louie's cousins at Engine 43."
  showSiteNav={false}
>
  <section class="hero-small">
    <div class="container">
      <h1>Fat Louie's Cousins</h1>
      <p>Meet the real cats of Engine 43.</p>
    </div>
  </section>

  <section class="section section-hero-flipped">
    <div class="container">
      <p class="intro">Fat Louie — Mia Thermopolis's orange tabby — is the fictional cat this firehouse is partly named after. But the real Engine 43 has its own crew.</p>

      <!-- MIA -->
      <h2 class="cat-name">Mia</h2>
      <p class="cat-bio">Named after the princess herself. She knows it.</p>
      <div class="cats-grid">
        <div class="cat-card"><Image src={mia} alt="Mia" widths={[400, 800]} sizes={catSizes} loading="lazy" class="align-top" /></div>
        <div class="cat-card"><Image src={miaSun} alt="Mia" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={mia2} alt="Mia" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
      </div>

      <!-- EMERALD -->
      <h2 class="cat-name">Emerald</h2>
      <p class="cat-bio">Green eyes, strong opinions, co-owner of the studio.</p>
      <div class="cats-grid">
        <div class="cat-card"><Image src={emerald} alt="Emerald" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={emerald2} alt="Emerald" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={emerald3} alt="Emerald" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
      </div>

      <!-- ZAPHIRE -->
      <h2 class="cat-name">Zaphire</h2>
      <p class="cat-bio">A true San Franciscan.</p>
      <div class="cats-grid">
        <div class="cat-card"><Image src={zaphire1} alt="Zaphire" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={zaphire2} alt="Zaphire" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={zaphire3} alt="Zaphire" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
      </div>

      <!-- MAJOR TOM -->
      <h2 class="cat-name">Major Tom</h2>
      <p class="cat-bio">Floating in a most peculiar way — usually on the best chair in the house.</p>
      <div class="cats-grid">
        <div class="cat-card"><Image src={majorTom} alt="Major Tom" widths={[400, 800]} sizes={catSizes} loading="lazy" class="align-top" /></div>
        <div class="cat-card"><Image src={tom1} alt="Major Tom" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={tom3} alt="Major Tom" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
      </div>

      <!-- TOGETHER -->
      <h2 class="cat-name">Together</h2>
      <p class="cat-bio">Inseparable. Unless there's only one sunny spot.</p>
      <div class="cats-grid">
        <div class="cat-card"><Image src={emeraldZaphire} alt="Emerald and Zaphire" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
<div class="cat-card"><Image src={emeraldZaphire2} alt="Emerald and Zaphire" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
        <div class="cat-card"><Image src={miaAndTom} alt="Mia and Major Tom" widths={[400, 800]} sizes={catSizes} loading="lazy" /></div>
      </div>

      <p class="back-link"><a href="/mia">&larr; Back to the firehouse</a></p>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" aria-modal="true" role="dialog" aria-label="Photo viewer">
    <button id="lb-close" aria-label="Close">&times;</button>
    <button id="lb-prev" aria-label="Previous">&#8592;</button>
    <button id="lb-next" aria-label="Next">&#8594;</button>
    <img id="lb-img" src="" alt="" />
  </div>
</BaseLayout>

<style>
  .intro {
    max-width: 620px;
    margin: 0 auto var(--spacing-2xl);
    text-align: center;
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .cat-name {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-xs);
  }

  .cat-bio {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .cats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .cat-card {
    min-width: 0;
    cursor: pointer;
  }

  .cat-card img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    transition: opacity 0.15s ease;
  }

  .cat-card:hover img {
    opacity: 0.85;
  }

  /* ── LIGHTBOX ── */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  #lightbox.open {
    display: flex;
  }

  #lb-img {
    max-width: calc(100vw - 120px);
    max-height: calc(100vh - 60px);
    object-fit: contain;
    border-radius: 4px;
    display: block;
  }

  #lb-close {
    position: fixed;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    padding: 4px 8px;
  }

  #lb-close:hover { opacity: 1; }

  #lb-prev,
  #lb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    opacity: 0.6;
    padding: 12px 16px;
    user-select: none;
  }

  #lb-prev:hover,
  #lb-next:hover { opacity: 1; }

  #lb-prev { left: 12px; }
  #lb-next { right: 12px; }

  .cat-card img.align-top {
    object-position: top;
  }

  .back-link {
    margin-top: var(--spacing-2xl);
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .cats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .cats-grid {
      grid-template-columns: 1fr;
    }

    #lb-img {
      max-width: 100vw;
    }

    #lb-prev { left: 4px; }
    #lb-next { right: 4px; }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbClose = document.getElementById('lb-close');
  const lbPrev = document.getElementById('lb-prev');
  const lbNext = document.getElementById('lb-next');

  const images = Array.from(document.querySelectorAll('.cat-card img'));
  let current = 0;

  function open(index) {
    current = index;
    const src = images[current].src;
    // Use the largest srcset src if available
    const srcset = images[current].srcset;
    if (srcset) {
      const last = srcset.split(',').pop().trim().split(' ')[0];
      lbImg.src = last || src;
    } else {
      lbImg.src = src;
    }
    lbImg.alt = images[current].alt;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  function prev() { open((current - 1 + images.length) % images.length); }
  function next() { open((current + 1) % images.length); }

  images.forEach((img, i) => {
    img.parentElement.addEventListener('click', () => open(i));
  });

  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>
