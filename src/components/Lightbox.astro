---
// Lightbox component — place on any page that has images with data-lightbox on their wrapper.
// The script collects all [data-lightbox] img elements and enables click-to-expand.
// Add data-lightbox-bg to a wrapper to show its CSS background-image behind the img in the lightbox.
---

<div id="lightbox" aria-modal="true" role="dialog" aria-label="Photo viewer">
  <button id="lb-close" aria-label="Close">&times;</button>
  <button id="lb-prev" aria-label="Previous">&#8592;</button>
  <button id="lb-next" aria-label="Next">&#8594;</button>
  <div id="lb-scene">
    <div id="lb-bg"></div>
    <img id="lb-img" src="" alt="" />
  </div>
</div>

<style>
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  #lightbox.open {
    display: flex;
  }

  #lb-scene {
    position: relative;
    max-width: calc(100vw - 120px);
    max-height: calc(100vh - 60px);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lb-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: none;
  }

  #lightbox.has-bg #lb-bg {
    display: block;
  }

  #lb-img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: calc(100vh - 60px);
    object-fit: contain;
    display: block;
  }

  @media (max-width: 480px) {
    #lb-scene {
      max-width: 100vw;
    }
  }

  #lb-close {
    position: fixed;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    padding: 4px 8px;
    z-index: 2;
  }

  #lb-close:hover { opacity: 1; }

  #lb-prev,
  #lb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    opacity: 0.6;
    padding: 12px 16px;
    user-select: none;
    z-index: 2;
  }

  #lb-prev:hover,
  #lb-next:hover { opacity: 1; }

  #lb-prev { left: 12px; }
  #lb-next { right: 12px; }

  @media (max-width: 480px) {
    #lb-img {
      max-width: 100vw;
    }

    #lb-prev { left: 4px; }
    #lb-next { right: 4px; }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lbBg = document.getElementById('lb-bg');
  const lbImg = document.getElementById('lb-img');
  const lbClose = document.getElementById('lb-close');
  const lbPrev = document.getElementById('lb-prev');
  const lbNext = document.getElementById('lb-next');

  const images = Array.from(document.querySelectorAll('[data-lightbox] img'));
  let current = 0;

  function open(index) {
    current = index;
    const img = images[current];
    const wrapper = img.closest('[data-lightbox]');
    const overrideSrc = wrapper && wrapper.dataset.lightboxSrc;
    const useBg = wrapper && wrapper.hasAttribute('data-lightbox-bg');

    if (overrideSrc) {
      lbImg.src = overrideSrc;
      lbBg.style.backgroundImage = '';
      lightbox.classList.remove('has-bg');
    } else if (useBg) {
      // Show the illustration, and put the CSS bg image behind it
      const srcset = img.srcset;
      if (srcset) {
        const last = srcset.split(',').pop().trim().split(' ')[0];
        lbImg.src = last || img.src;
      } else {
        lbImg.src = img.src;
      }
      // Walk up to find the computed background-image
      let el = wrapper;
      let bgUrl = '';
      while (el && !bgUrl) {
        const bg = getComputedStyle(el).backgroundImage;
        const match = bg.match(/url\(["']?([^"')]+)["']?\)/);
        if (match) bgUrl = match[1];
        el = el.parentElement;
      }
      lbBg.style.backgroundImage = bgUrl ? 'url(' + bgUrl + ')' : '';
      lightbox.classList.toggle('has-bg', !!bgUrl);
    } else {
      const srcset = img.srcset;
      if (srcset) {
        const last = srcset.split(',').pop().trim().split(' ')[0];
        lbImg.src = last || img.src;
      } else {
        lbImg.src = img.src;
      }
      lbBg.style.backgroundImage = '';
      lightbox.classList.remove('has-bg');
    }

    lbImg.alt = img.alt;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  function prev() { open((current - 1 + images.length) % images.length); }
  function next() { open((current + 1) % images.length); }

  images.forEach((img, i) => {
    img.closest('[data-lightbox]').addEventListener('click', () => open(i));
  });

  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>
